rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Utility functions
    function isLoggedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isLoggedIn() && request.auth.uid == userId;
    }
    function isAdmin() {
      let uid = request.auth.uid;
      return isLoggedIn() && (
        exists(/databases/$(database)/documents/admins/$(uid)) ||
        get(/databases/$(database)/documents/users/$(uid)).data.role == 'admin' ||
        get(/databases/$(database)/documents/users/$(uid)).data.role == 'super_admin' ||
        get(/databases/$(database)/documents/users/$(uid)).data.role == 'orders_manager' ||
        get(/databases/$(database)/documents/users/$(uid)).data.role == 'accountant_admin' ||
        get(/databases/$(database)/documents/users/$(uid)).data.role == 'marketing_admin'
      );
    }

    // User profiles
    match /users/{userId} {
      allow read: if isLoggedIn() && (isOwner(userId) || isAdmin());
      allow create: if isLoggedIn();
      allow update: if isLoggedIn() && (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();
    }

    // Account deletion requests
    match /account_deletions/{deletionId} {
      allow create: if isLoggedIn();
      allow read, update, delete: if isAdmin();
    }

    // Support Tickets
    match /support_tickets/{ticketId} {
      allow create: if isLoggedIn();
      allow read, update: if isLoggedIn() && (request.auth.uid == resource.data.userId || isAdmin());
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read, create: if isLoggedIn() && (
          request.auth.uid == get(/databases/$(database)/documents/support_tickets/$(ticketId)).data.userId
          || isAdmin()
        );
      }
    }

    // Legacy Tickets Collection
    match /tickets/{ticketId} {
      allow read, update: if isLoggedIn() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isLoggedIn();
      allow delete: if isAdmin();
    }

    // Orders & Transactions
    match /orders/{orderId} {
      allow read: if isLoggedIn() && (request.auth.uid == resource.data.client_id || request.auth.uid == resource.data.driver_id || isAdmin());
      allow create: if isLoggedIn();
      allow update: if isLoggedIn() && (
        request.auth.uid == resource.data.client_id || 
        request.auth.uid == resource.data.driver_id || 
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Driver Data
    match /drivers/{driverId} {
      allow read: if isLoggedIn() && (request.auth.uid == driverId || isAdmin());
      allow write, update: if isAdmin();
    }

    // FCM Tokens
    match /fcm_tokens/{tokenId} {
      allow read, write: if isLoggedIn() && (request.auth.uid == tokenId || isAdmin());
    }

    // Electronic Contracts
    match /contracts/{contractId} {
      allow create: if isLoggedIn();
      allow read, update: if isLoggedIn() && (request.auth.uid == resource.data.userId || isAdmin());
      allow delete: if isAdmin();
    }

    // Maintenance Requests
    match /maintenance_requests/{requestId} {
      allow create: if isLoggedIn();
      allow read, update: if isLoggedIn() && (request.auth.uid == (resource == null ? request.resource.data.userId : resource.data.userId) || isAdmin());
      allow delete: if isAdmin();
    }

    // Marketing & Content
    match /subscription_packages/{packageId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }
    match /promo_banners/{bannerId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }
    match /promo_codes/{codeId} {
      allow read: if isLoggedIn();
      allow update: if isLoggedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['uses']);
      allow write: if isAdmin();
    }
    match /coupons/{couponId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    // System Settings
    // System Settings
    match /system_configs/{configId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }
    match /metadata/{docId} {
      allow get, create, update: if isLoggedIn() && docId == 'order_counter';
    }
    match /admins/{adminId} {
      allow read: if isLoggedIn() && (request.auth.uid == adminId || isAdmin());
      allow write: if isAdmin();
    }
    match /services/{serviceId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    // Store Section
    match /products/{productId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }
    match /store_orders/{orderId} {
      allow create: if isLoggedIn();
      allow read: if isLoggedIn() && (request.auth.uid == resource.data.client_id || isAdmin());
      allow update, delete: if isAdmin();
    }

    // Geographic Zones
    match /regions/{regionId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }
    match /hourly_zones/{zoneId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    // Logs & Triggers
    match /audit_logs/{logId} {
      allow create: if isLoggedIn();
      allow read, delete: if isAdmin();
    }
    match /notification_triggers/{triggerId} {
      allow create: if isLoggedIn() && (
        request.resource.data.toUid == request.auth.uid || 
        request.resource.data.toUid == 'ADMIN_BROADCAST'
      );
      allow read, delete: if isAdmin();
    }
    match /notifications_log/{logId} {
      allow read, write: if isAdmin();
    }
    match /marketing_campaigns/{campaignId} {
      allow read, write: if isAdmin();
    }
    match /config/{configId} {
      allow read, write: if isAdmin();
    }
    match /broadcasts/{broadcastId} {
      allow read, write: if isAdmin();
    }
    match /scheduled_notifications/{notifId} {
      allow read, write: if isAdmin();
    }
    match /notifications/{notifId} {
      allow read: if isLoggedIn() && (request.auth.uid == resource.data.userId || isAdmin());
      allow write: if isAdmin();
    }
  }
}
