rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Utility functions
    function isLoggedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isLoggedIn() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isLoggedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // User profiles
    match /users/{userId} {
      allow read: if isLoggedIn() && (isOwner(userId) || isAdmin());
      allow create: if isLoggedIn();
      allow update: if isLoggedIn() && isOwner(userId);
      allow delete: if isAdmin();
    }

    // Account deletion requests
    match /account_deletions/{deletionId} {
      allow create: if isLoggedIn();
      allow read, update, delete: if isAdmin();
    }

    // Support Tickets
    match /support_tickets/{ticketId} {
      allow create: if isLoggedIn();
      allow read, update: if isLoggedIn() && (request.auth.uid == resource.data.userId || isAdmin());
      allow delete: if isAdmin();

      match /messages/{messageId} {
        // Only ticket owner or admin can read/write messages
        allow read, create: if isLoggedIn() && (
          request.auth.uid == get(/databases/$(database)/documents/support_tickets/$(ticketId)).data.userId
          || isAdmin()
        );
      }
    }

    // Legacy Tickets Collection (Protected)
    match /tickets/{ticketId} {
      allow read, update: if isLoggedIn() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isLoggedIn();
      allow delete: if isAdmin();
    }

    // Orders & Transactions (Hardened)
    match /orders/{orderId} {
      allow read: if isLoggedIn() && (request.auth.uid == resource.data.client_id || request.auth.uid == resource.data.driver_id || isAdmin());
      allow create: if isLoggedIn() && (request.resource.data.status == 'pending' || request.resource.data.status == 'waiting_payment_cod');
      allow update: if isLoggedIn() && (request.auth.uid == resource.data.driver_id || isAdmin());
      allow delete: if isAdmin();
    }

    // Driver Data
    match /drivers/{driverId} {
      allow read: if isLoggedIn() && (request.auth.uid == driverId || isAdmin());
      allow write: if isAdmin();
      allow update: if isLoggedIn() && (request.auth.uid == driverId || isAdmin());
    }

    // FCM Tokens
    match /fcm_tokens/{tokenId} {
      allow read, write: if isLoggedIn() && (request.auth.uid == tokenId || isAdmin());
    }

    // Electronic Contracts
    match /contracts/{contractId} {
      allow create: if isLoggedIn();
      allow read, update: if isLoggedIn() && (request.auth.uid == resource.data.userId || isAdmin());
      allow delete: if isAdmin();
    }

    // Maintenance Requests
    match /maintenance_requests/{requestId} {
      allow create: if isLoggedIn();
      allow read: if isLoggedIn() && (request.auth.uid == resource.data.userId || isAdmin());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // System Admins (Restricted access)
    match /admins/{adminId} {
      allow read: if isLoggedIn() && (request.auth.uid == adminId || isAdmin());
      allow write: if isAdmin(); // Only super admins can add other managers
    }

    // Dynamic Services
    match /services/{serviceId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    // Store Section
    match /products/{productId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }
    match /store_orders/{orderId} {
      allow create: if isLoggedIn();
      allow read, update, delete: if isAdmin();
    }

    // Notification Triggers (SECURITY HARDENED)
    match /notification_triggers/{triggerId} {
      // Users can only create triggers of type 'maintenance_request' or 'order' for themself
      allow create: if isLoggedIn() && request.resource.data.userId == request.auth.uid;
      allow read, delete: if isAdmin();
    }
  }
}

